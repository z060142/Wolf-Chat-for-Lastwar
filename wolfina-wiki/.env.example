# Wolfina-Wiki Configuration
# Copy this file to .env and fill in your values

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///./wolfina.db

# --- API server port ---
API_PORT=8765

# --- LLM Provider: "ollama" or "openai" ---
LLM_PROVIDER=ollama

# Ollama Cloud settings (used when LLM_PROVIDER=ollama)
OLLAMA_API_KEY=your_ollama_api_key_here
OLLAMA_HOST=https://ollama.com
OLLAMA_MODEL=gpt-oss:120b

# OpenAI / OpenRouter settings (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=openai/gpt-4o

# --- Conversation trigger thresholds ---
TRIGGER_MSG_COUNT=20
TRIGGER_CHAR_COUNT=2000
TRIGGER_DURATION_SEC=300
